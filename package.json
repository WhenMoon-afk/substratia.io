{
  "name": "substratia",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev --filter=!@substratia/mobile",
    "dev:web": "turbo dev --filter=@substratia/web",
    "dev:mobile": "turbo dev --filter=@substratia/mobile",
    "dev:convex": "turbo dev --filter=@substratia/convex",
    "build": "turbo build --filter=!@substratia/mobile",
    "build:web": "turbo build --filter=@substratia/web",
    "lint": "turbo lint --filter=!@substratia/mobile",
    "typecheck": "turbo typecheck --filter=!@substratia/mobile",
    "android": "cd apps/mobile && bunx expo run:android",
    "android:build": "cd apps/mobile && bunx eas build --platform android",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "turbo": "^2.9.6"
  },
  "packageManager": "bun@1.1.0",
  "dependencies": {
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.12",
    "flatted": "3.4.2",
    "lodash": "4.18.1",
    "node-forge": "1.4.0",
    "tar": "7.5.13",
    "undici": "6.24.1"
  }
}
