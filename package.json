{
  "name": "substratia",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev --filter=!@substratia/mobile",
    "dev:web": "turbo dev --filter=@substratia/web",
    "dev:mobile": "turbo dev --filter=@substratia/mobile",
    "dev:convex": "turbo dev --filter=@substratia/convex",
    "build": "turbo build --filter=!@substratia/mobile",
    "build:web": "turbo build --filter=@substratia/web",
    "lint": "turbo lint --filter=!@substratia/mobile",
    "typecheck": "turbo typecheck --filter=!@substratia/mobile",
    "android": "pnpm --dir apps/mobile exec expo run:android",
    "android:build": "pnpm --dir apps/mobile exec eas build --platform android",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "turbo": "^2.9.6",
    "tsx": "^4.21.0"
  },
  "packageManager": "pnpm@11.1.2",
  "dependencies": {
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  }
}
